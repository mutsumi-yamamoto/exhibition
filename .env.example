# Gemini API Key
# Google AI Studio (https://aistudio.google.com/) で取得
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets スプレッドシートID
# スプレッドシートのURLの /d/ と /edit の間の文字列
SPREADSHEET_ID=your_spreadsheet_id_here

# サービスアカウントのJSONキーファイルパス
# GCP Console > IAM > サービスアカウント で作成・ダウンロード
SERVICE_ACCOUNT_JSON=service_account.json

# 書き込み先シート名（デフォルト: マスター）
SHEET_NAME=マスター

# Google Drive 名刺画像保存先フォルダID
# Drive フォルダのURLの /folders/ 以降の文字列
DRIVE_FOLDER_ID=your_drive_folder_id_here
